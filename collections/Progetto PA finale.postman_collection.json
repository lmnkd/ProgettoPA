    {
      "name": "Login utenti",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Login status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "let json = {};\r",
              "try {\r",
              "    json = pm.response.json();\r",
              "} catch (e) {\r",
              "    console.log(\"Response is not JSON\");\r",
              "}\r",
              "\r",
              "if (json.token) {\r",
              "    pm.environment.set(\"JWT_TOKEN\", json.token);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
