    {
      "name": "Creazione codice Redis",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is success\", function () {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);\r",
              "});\r",
              "\r",
              "try {\r",
              "    const json = pm.response.json();\r",
              "\r",
              "    if (json.code) {\r",
              "        pm.environment.set(\"CODE\", json.code);\r",
              "        console.log(\"CODE salvato:\", json.code);\r",
              "    } else {\r",
              "        console.log(\"La risposta non contiene il campo 'code'\");\r",
              "    }\r",
              "} catch (error) {\r",
              "    console.log(\"Risposta non JSON o parsing fallito:\", error);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
