{
"name": "progetto-pa",
"version": "1.0.0",
"description": "Progetto di Programmazione Avanzata",
"main": "dist/app.js",

"jest": {
"preset": "ts-jest",
"testEnvironment": "node",
"roots": ["<rootDir>/src"],
"testMatch": ["**/test/**/*.test.ts"],
"clearMocks": true
},

"scripts": {
"dev": "nodemon src/server.ts",
"build": "tsc",
"start": "node dist/server.js",
"test": "jest",
"buildModels": "sequelize-auto --sg=true -l ts -o ./src/models -h localhost -d pa2425 -u postgres -x postgres -p 5432 -e postgres --useDefine --cm=p --cp=c --cf=p --noAlias"
},

"repository": {
"type": "git",
"url": ""
},

"author": "Manuel Mulloni",
"license": "ISC",
"homepage": "",

"dependencies": {
"bcrypt": "5.1.0",
"dotenv": "16.3.1",
"express": "5.2.1",
"jsonwebtoken": "9.0.2",
"pdfkit": "0.13.0",
"pg": "8.11.1",
"redis": "4.6.7",
"sequelize": "6.32.1",
"sequelize-auto": "0.8.0"
},

"devDependencies": {
"@types/bcrypt": "5.0.2",
"@types/express": "4.17.17",
"@types/jest": "29.5.12",
"@types/jsonwebtoken": "9.0.2",
"@types/node": "20.11.1",
"@types/pdfkit": "0.13.5",
"@types/redis": "4.0.11",
"@types/sequelize": "^4.28.20",
"jest": "29.7.0",
"nodemon": "2.0.22",
"ts-jest": "29.4.11",
"typescript": "5.1.6"
}
}
